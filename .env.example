# Port for the API server (default 3000)
PORT=3838

# ── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_USERNAME=mediamanbot
ADMIN_PASSWORD=qodkgkeu2@17038!jkfhu
JWT_SECRET=kosdrjgihiuyh58jnkholso84lky78irekjnbhjadhh456789

# ── Public API Key (single key for all external API calls) ────────────────────
API_KEY=KdhfosadhfkljOPO97u9454klmjslujLKHIUTYIUyiokjnaefpo009789iy435jiuyS

# ── Storage ──────────────────────────────────────────────────────────────────
# Use in-memory store (boolean). true = store in RAM (no MySQL; data lost on restart). false = use MySQL (default).
USE_MEMORY=true

# MySQL (used when USE_MEMORY is false). DB and tables are created on startup if missing.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=livmantra
MYSQL_PASSWORD=livmantra
MYSQL_DATABASE=shamcash_api

# Cleanup (in-process; no external cron needed). Pending = QR sessions never scanned.
# PENDING_SESSION_TTL_MS=900000   # 15 min (default)
# CLEANUP_INTERVAL_MS=300000      # 5 min (default)

# ── Mobile API base URLs (api.shamcash.sy) ────────────────────────────────────
# Defaults are correct — only override for testing
# SHAMCASH_API_BASE=https://api.shamcash.sy/v4/api
# SHAMCASH_API_BASE_02=https://api-02.shamcash.sy/v4/api
# SHAMCASH_API_BASE_03=https://api-03.shamcash.sy/v4/api
# SHAMCASH_BANK_API_BASE=https://bank.shamcash.sy/v4/api
# SHAMCASH_PAYMENT_API_BASE=https://payment.shamcash.sy/v4/api

# Locale sent in 'lang' header
# SHAMCASH_LOCALE=en

