# Port for the API server (default 3000)
PORT=3009

# ── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=change-this-to-a-random-secret-string

# ── Public API Key (single key for all external API calls) ────────────────────
API_KEY=your-api-key-here

# ── Storage ──────────────────────────────────────────────────────────────────
# Use in-memory store (boolean). true = store in RAM (no MySQL; data lost on restart). false = use MySQL (default).
USE_MEMORY=false

# MySQL (used when USE_MEMORY is false). DB and tables are created on startup if missing.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=shamcash_api

# Cleanup (in-process; no external cron needed). Pending = QR sessions never scanned.
# PENDING_SESSION_TTL_MS=900000   # 15 min (default)
# CLEANUP_INTERVAL_MS=300000      # 5 min (default)

# ── Mobile API (api.shamcash.sy) ──────────────────────────────────────────────
# Primary and failover base URLs (matching app's FailoverInterceptor).
# Defaults are the correct production values — only override for testing.
# SHAMCASH_API_BASE=https://api.shamcash.sy/v4/api
# SHAMCASH_API_BASE_02=https://api-02.shamcash.sy/v4/api
# SHAMCASH_API_BASE_03=https://api-03.shamcash.sy/v4/api
# SHAMCASH_BANK_API_BASE=https://bank.shamcash.sy/v4/api
# SHAMCASH_PAYMENT_API_BASE=https://payment.shamcash.sy/v4/api

# Locale sent in 'lang' header (default: en)
# SHAMCASH_LOCALE=en

# ── Encryption ────────────────────────────────────────────────────────────────
# Fixed AES-192-GCM key used for all authenticated requests (BZ/SL functions).
# This is the 24-char key from assets/aes_key.pem in the APK.
SHAMCASH_AES_KEY=g0Zrgp8XRK/BN2ZAtUfJDQ==

# RSA public key for Session/create (yv function). From assets/public_server_new.pem.
# Use base64-only (no newlines) to avoid PM2/systemd truncating env vars at newlines.
SHAMCASH_SERVER_PUBLIC_

# ── Fake Android device info (InfoDeviceModel sent on login) ──────────────────
# DEVICE_NAME=Pixel 7
# DEVICE_OS=Android 14
# DEVICE_BRAND=Google
# DEVICE_MODEL=Pixel 7
# DEVICE_TOKEN=   # FCM token — leave blank to auto-generate a fake one
